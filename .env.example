# ============================================================
#  ACME ERP - Variables de entorno (PLANTILLA)
#  Copiar a .env y completar.  NUNCA subir el .env real a GitHub.
# ============================================================

# ---- Servidor Frontend (Node.js / Express) ----
NODE_ENV=production
PORT=3000

# Secreto para firmar los JWT (token de acceso condicional).
# Generar uno robusto:  openssl rand -hex 32
JWT_SECRET=CAMBIAR_por_un_valor_aleatorio_de_64_hex
JWT_EXPIRES_IN=30m

# ---- Base de datos PaaS: AWS RDS PostgreSQL ----
# El DB_HOST es el endpoint del RDS, p.ej.:
#   acme-erp-db.abc123xyz.us-east-1.rds.amazonaws.com
DB_HOST=acme-erp-db.xxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=acme_erp
DB_USER=acme_app
DB_PASSWORD=CAMBIAR_password_robusto
# Conexión cifrada obligatoria (TLS). Ruta del bundle CA de AWS dentro del contenedor.
DB_SSL=true
DB_SSL_CA=/app/certs/rds-combined-ca-bundle.pem

# ---- AWS (para backups a S3) ----
AWS_REGION=us-east-1
S3_BACKUP_BUCKET=acme-erp-backups-2026
# En EC2 se recomienda usar un IAM Role (instance profile) en vez de claves.
# Si se usan claves, completar (no recomendado en producción):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
